# Dotty — self-hosted StackChan robot assistant
# Copy to .env and fill in real values before deploying.

# --- xiaozhi-esp32-server (compose.yml) ---

# Container timezone (IANA format).
TZ=Australia/Brisbane

# Client-visible URL bases. Include only the scheme, host, and optional port;
# make setup appends the fixed /xiaozhi/... endpoint suffix.
XIAOZHI_PUBLIC_WS_BASE_URL=ws://192.168.1.10:8000
XIAOZHI_PUBLIC_OTA_BASE_URL=http://192.168.1.10:8003

# Host-published ports for hardware/browser/local diagnostics. Internal compose
# calls use service DNS names instead. DOTTY_BEHAVIOUR_PORT and
# DOTTY_BRIDGE_PORT are optional; omit them to use compose.yml defaults.
XIAOZHI_WS_PORT=8000
XIAOZHI_HTTP_PORT=8003
DOTTY_BEHAVIOUR_PORT=8090
DOTTY_BRIDGE_PORT=8081
# DOTTY_PI_RPC_PORT=8091

# Persistent host directories. Compose defaults target the reference Unraid
# layout; override these on other hosts.
# DOTTY_PI_STATE_DIR=/mnt/user/appdata/dotty-pi
# DOTTY_BEHAVIOUR_STATE_DIR=/mnt/user/appdata/dotty-behaviour
# DOTTY_BRIDGE_STATE_DIR=/mnt/user/appdata/dotty-bridge

# Optional local image names. BRIDGE_VERSION is normally stamped by make or
# scripts/deploy-stack.sh.
# XIAOZHI_BASE_IMAGE=dotty-xiaozhi-base:torch2.7.1-cu128
# XIAOZHI_IMAGE_TAG=xiaozhi-esp32-server-chattts:local
# DOTTY_PI_IMAGE_TAG=dotty-pi:0.1.0
# DOTTY_BEHAVIOUR_IMAGE_TAG=dotty-behaviour:0.1.0
# DOTTY_BRIDGE_IMAGE_TAG=dotty-bridge:0.1.0
# BRIDGE_VERSION=unknown

# Optional persona placeholders rendered into data/.config.yaml.
ROBOT_NAME=Dotty
YOUR_NAME=household

# ASR acceleration policy. `auto` detects the NVIDIA Docker runtime and selects
# FunASR/CUDA when available, otherwise FunASR/CPU. After building the
# xiaozhi image, setup also executes a real provider-specific CUDA kernel
# through the Compose service. It writes the resolved values below into
# .env so later plain `docker compose up` uses the same result. Use `cpu` or
# `cuda` to force a mode, or `manual` to own all resolved values yourself.
ASR_ACCELERATION=auto
# SenseVoice language: auto, zh, en, yue, ja, ko, or nospeech.
ASR_LANGUAGE=auto
# ASR_MODULE=FunASR
# ASR_DEVICE=cpu
# ASR_COMPUTE_TYPE=float32  # FunASR default; manual Whisper uses CTranslate2 values
# XIAOZHI_CONTAINER_RUNTIME=runc
# NVIDIA_VISIBLE_DEVICES=void
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
# PERSONA=default
# MIN_UTTERANCE_CHARS=2

# Optional build mirrors. The official npm registry is used by default.
# PIP_INDEX_URL=
# NPM_CONFIG_REGISTRY=
# TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
# TORCH_WHEEL_BASE_URL=https://download.pytorch.org/whl/cu128
# ChatTTS model mirror. The default avoids runtime model downloads.
# CHAT_TTS_REPO=https://hf-mirror.com/2Noise/ChatTTS

# Optional profile. Set to local-llm to start the Ollama service defined in
# compose.yml. Point dotty-pi and the behaviour narrative route at Compose DNS.
# COMPOSE_PROFILES=local-llm
# OLLAMA_PORT=11434
# NARRATIVE_LLM_URL=http://ollama:11434/v1
# NARRATIVE_MODEL=qwen3:8b

# --- Kid Mode (child-safe guardrails) ---

# Set to "true" (default) to enable child-safe rules: age-appropriate
# vocabulary, topic blocklist, self-harm redirect, jailbreak resistance.
# Set to "false" for general-purpose assistant mode.
DOTTY_KID_MODE=true

# --- Admin API auth (X-Admin-Token) ---

# Shared secret protecting the /xiaozhi/admin/* routes (inject-text, say,
# set-state, play-asset, ...). Generate a real value before running setup:
# openssl rand -hex 32
#
# Xiaozhi keeps legacy permissive semantics when unset; bridge `/admin/*`
# fails closed. The all-in-one deployment requires this value so every service
# shares the same admin auth.
#
# Every caller reads this SAME variable from the root .env.
DOTTY_ADMIN_TOKEN=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE

# --- StackChan simulator (optional Compose profile) ---
# Normal `docker compose up -d` does not start it. Run `make simulator`.
# STACKCHAN_SIMULATOR_IMAGE_TAG=stackchan-simulator:0.1.0
# STACKCHAN_SIMULATOR_PORT=8082
# STACKCHAN_SIMULATOR_DEVICE_ID=stackchan-sim-001

# Optional dashboard protection. CSRF signing derives a stable key from
# DOTTY_ADMIN_TOKEN unless a separate secret is provided here.
# DOTTY_CSRF_SECRET=
# DOTTY_CSRF_ENFORCE=1
# DOTTY_DASHBOARD_USER=
# DOTTY_DASHBOARD_PASS=
# DOTTY_BRIDGE_LOG_LEVEL=info

# --- Perception: face greeter ---

# What the bridge says when a face is freshly detected. The firmware
# also fires WakeWordInvoke("face") on detection, which opens the mic
# regardless of this value. Trade-off:
#
#   FACE_GREET_TEXT="Hi!"   → popup chime + verbal "Hi!" + mic open
#                             (warmer; slightly noisy in everyday use)
#   FACE_GREET_TEXT=""      → popup chime + mic open, silent greeting
#                             (less chatty; mic still listens)
#
# Default is "Hi!". Set to "" to keep the mic-open behaviour without
# the verbal greeting.
# FACE_GREET_TEXT=Hi!

# Minimum seconds between consecutive face-detected greetings for the
# same device. Stops the robot re-greeting on every casual walk-by
# while still re-engaging after a real absence. The face state machine
# bounces in/out of the 2 s grace period during normal head movements,
# so any value below ~10 s will feel chatty. Default 30 s.
# FACE_GREET_MIN_INTERVAL_SEC=30

# Legacy alias for FACE_GREET_MIN_INTERVAL_SEC. Honoured for back-
# compat — set the new name on fresh deployments.
# FACE_GREET_COOLDOWN_SEC=30

# --- Purr-on-head-pet (Phase 1.7, Option B server-pushed) ---

# The purr asset is baked from bridge/assets/purr.opus into the xiaozhi image.
# See bridge/assets/README.md for the format, then rebuild xiaozhi-server.

# Per-device cooldown so a continuous head-pet doesn't re-trigger
# the clip on every event burst. Default 5 s.
# PURR_COOLDOWN_SEC=5

# Approximate playback duration. Used to extend `last_chat_t` while
# the purr plays so the sound localizer doesn't turn the head toward
# the speaker mid-purr. Match this to your purr.opus length.
# PURR_DURATION_SEC=2.0

# --- API keys (secrets — never commit real values) ---

# Required if using OpenAICompat LLM provider with a cloud endpoint.
# Get one at https://openrouter.ai/keys (OpenRouter) or https://platform.openai.com/api-keys (OpenAI).
# Not needed if running fully local via Ollama.
# OPENROUTER_API_KEY=sk-or-v1-...

# Required if using the vision feature (camera -> VLM description).
# Same key as above works if your provider supports vision models.
# VISION_API_KEY=sk-or-v1-...

# --- dotty-pi / PiVoiceLLM sub2api routing ---
#
# dotty-pi renders /root/.pi/agent/models.json from these variables at
# container start. DOTTY_PI_PROVIDER is both the provider key in models.json
# and the provider used by the pi outer loop. DOTTY_PI_MODEL is both the
# simple-route model id in models.json and the model used by the pi outer loop.
#
DOTTY_PI_BASE_URL=https://DOTTY_PI_BASE_URL_PLACEHOLDER/v1
DOTTY_PI_API_KEY=sk-...
DOTTY_PI_PROVIDER=sub2api
DOTTY_PI_MODEL=dotty-simple
# Select a persona already baked into the dotty-pi image.
# DOTTY_PI_SYSTEM_PROMPT_FILE=/opt/dotty-pi/personas/dotty_voice.md
DOTTY_PI_PROVIDER_API=openai-completions
DOTTY_PI_SUPPORTS_DEVELOPER_ROLE=false
DOTTY_PI_SUPPORTS_REASONING_EFFORT=true
DOTTY_PI_SIMPLE_MODEL_NAME=Dotty simple route (sub2api)
DOTTY_PI_SIMPLE_REASONING=false
DOTTY_PI_SIMPLE_REASONING_EFFORT=
DOTTY_PI_SIMPLE_CONTEXT_WINDOW=128000
DOTTY_PI_SIMPLE_MAX_TOKENS=2048
DOTTY_PI_THINK_MODEL_NAME=Dotty think_hard route (sub2api)
DOTTY_PI_THINK_REASONING=true
DOTTY_PI_THINK_REASONING_EFFORT=high
DOTTY_PI_THINK_CONTEXT_WINDOW=128000
DOTTY_PI_THINK_MAX_TOKENS=4096
VOICE_THINKER_MODEL=dotty-think
VOICE_THINKER_API_KEY=
# Optional when think_hard uses a different endpoint. Otherwise the URL is
# derived as DOTTY_PI_BASE_URL + /chat/completions and the main API key is used.
# VOICE_THINKER_URL=
# VOICE_THINKER_TIMEOUT=30
# DOTTY_PI_TURN_TIMEOUT_MS=120000
# DOTTY_PI_TURN_TIMEOUT_SEC=120
# DOTTY_BEHAVIOUR_TIMEOUT_MS=3000
# DOTTY_PI_EXTRA_FLAGS=

# Optional narrative/vision routes used by dotty-behaviour.
# NARRATIVE_LLM_URL=http://host.docker.internal:8080/v1
# NARRATIVE_MODEL=qwen3.6:27b-think
# NARRATIVE_TIMEOUT_SEC=90
# VISION_MODEL=google/gemini-3.1-flash-lite
# VISION_API_URL=https://openrouter.ai/api/v1/chat/completions
# VLM_API_KEY=
# VLM_MODEL=google/gemini-3.1-flash-lite
# VLM_API_URL=https://openrouter.ai/api/v1/chat/completions
# AUDIO_CAPTION_API_KEY=
# AUDIO_CAPTION_MODEL=google/gemini-2.5-flash
# AUDIO_CAPTION_API_URL=https://openrouter.ai/api/v1/chat/completions

# --- Google Calendar integration (optional) ---

# Comma-separated Google Calendar IDs for context injection.
# Requires `google-calendar-sa.json` in the dotty-behaviour secrets directory.
# CALENDAR_ID=abc123@group.calendar.google.com

# Background poll cadence for the calendar cache refresher (seconds).
# Default 900 s = 15 min. Lower than CALENDAR_TTL_SEC so transient
# fetch failures don't leave a stale cache visible for the full TTL.
# CALENDAR_POLL_SEC=900

# Per-event person tag regex. Must define named groups `person` and
# `rest`. Default extracts `[Name] real summary` where Name is 1-32
# chars of [A-Za-z0-9_-] starting with a letter. Untagged events are
# bucketed under CALENDAR_HOUSEHOLD_BUCKET.
# CALENDAR_PERSON_PREFIX_RE=^\s*\[(?P<person>[A-Za-z][A-Za-z0-9_-]{0,31})\]\s*(?P<rest>.+)$

# Bucket name for events with no person tag. Leading underscore so it
# can't collide with a real first name typed into a calendar event.
# CALENDAR_HOUSEHOLD_BUCKET=_household

# --- Household registry ---
# Path to the YAML file that lists who lives here (display names,
# personalities, calendar prefixes, self-ID phrases, birthdates). The
# registry powers the speaker resolver, the proactive greeter, and the
# `[Speaking with]` block in voice prompts. Hot-reloaded on file change.
# Empty / missing file is fine — everyone resolves to `_household`.
# See `household.example.yaml` at the repo root for the schema. Store the live
# file as `state/household.yaml` under DOTTY_BEHAVIOUR_STATE_DIR.

# --- Speaker resolver (Phase 1 identity) ---
# How long a self-ID phrase like "It's Brett" latches the channel onto
# that person. Default 600 s (10 min) — covers a typical conversation
# without dropping the user mid-thought. Anyone can override mid-session
# by saying another self-ID phrase ("It's Sam").
# SPEAKER_STICKY_SEC=600

# How wide a window (in minutes) calendar `[Person]` events still count
# as a prior. Defaults to 30 min — tight enough that "Hudson's library
# day at 10am" doesn't bias inputs at 5pm.
# SPEAKER_CALENDAR_WINDOW_MIN=30

# How recent a `face_recognized` perception event must be to vote.
# Default 30 s. Inert today (Layer 4 face-rec firmware not shipped);
# becomes the dominant signal once it lands.
# SPEAKER_PERCEPTION_WINDOW_SEC=30

# Below this confidence the resolver flags `ask_clarification=True` so
# the bridge can surface "Is that you, Hudson?" instead of guessing.
# SPEAKER_ASK_THRESHOLD=0.5

# --- Proactive Greetings (Layer 6) ---
# Server-initiated greetings when a recognised face walks into frame.
# See docs/proactive-greetings.md for the full architecture.

# Master kill switch.
# GREETER_ENABLED=true

# Subscribe to face_detected as a fallback while Layer 4 face
# recognition isn't fully wired. Treats every detection as
# identity=unknown — combine with GREETER_GREET_UNKNOWN to actually
# fire a greeting.
# GREETER_USE_FACE_DETECTED=false

# Greet unrecognised faces with a generic "Hello! I don't think we've met."
# GREETER_GREET_UNKNOWN=false

# Minimum hours between greetings for the same identity.
# GREETER_COOLDOWN_HOURS=4

# Hard cap on greetings per identity per day. Cooldown already prevents
# back-to-back firings; this is a ceiling, not a politeness lever.
# GREETER_PER_DAY_MAX=3

# The persistent greet log is stored under DOTTY_BEHAVIOUR_STATE_DIR/state.

# Word cap fed to the LLM prompt.
# GREETER_GREETING_MAX_WORDS=15

# --- Blind mode (low-light camera handling) ---
# The OV-series camera produces unusable frames in the dark. When blind
# mode is active (civil dusk → civil dawn at the configured location):
#   • the face-greeter ignores face_detected events (no 3 AM greets to
#     noisy frames)
#   • /api/vision/explain short-circuits with DOTTY_BLIND_PHOTO_REPLY
#     instead of feeding a near-black JPEG to the VLM
#   • [Context: ...] in the voice prompt notes "It's nighttime and Dotty
#     can't see well right now" so unprompted "what do you see?" gets a
#     sensible answer instead of a hallucination.
# Defaults match LOCAL_TZ (Brisbane). Set DOTTY_BLIND_MODE=false to
# disable all blind-mode gating (operator killswitch).
# DOTTY_BLIND_MODE=true
# DOTTY_BLIND_LAT=-27.47
# DOTTY_BLIND_LON=153.03
# DOTTY_BLIND_PHOTO_REPLY=It's too dark to see right now. Can you turn a light on?

# --- Debug flags ---

# (No bridge debug flags currently. The former ZEROCLAW_STREAM_DEBUG flag
# was retired with the ZeroClaw voice path in the #36 cutover.)
