{
  "name": "stackchan-simulator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "vite build && rm -rf dist-server && tsc -p tsconfig.server.json",
    "dev": "node --env-file-if-exists=../.env --watch --import tsx server/index.ts",
    "start": "node --env-file-if-exists=../.env dist-server/index.js",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.2.0",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.4.0",
    "lucide-react": "^0.468.0",
    "opusscript": "^0.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
