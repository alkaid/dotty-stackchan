# Copy to .env and fill in. .env is git-ignored — never commit your token.

# Bot token from the Discord Developer Portal (Bot tab -> Reset Token).
DISCORD_BOT_TOKEN=

# Target server ID. Optional: leave blank if the bot is in only one server.
# To get it: enable Developer Mode (User Settings -> Advanced), then
# right-click the server icon -> Copy Server ID.
DISCORD_GUILD_ID=
